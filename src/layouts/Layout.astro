---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Explore Physics' } = Astro.props;
---

<!doctype html>
<html lang="de" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Interactive physics experiments for students" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100">
    <header class="border-b border-slate-700 bg-slate-800/80 backdrop-blur sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={`${import.meta.env.BASE_URL}`} class="text-xl font-bold text-indigo-400 hover:text-indigo-300 transition-colors">
          ⚛️ Explore Physics
        </a>
        <div class="flex items-center gap-4">
          <a href={`${import.meta.env.BASE_URL}`} class="text-sm text-slate-300 hover:text-white transition-colors">Home</a>
          <button
            id="lang-toggle"
            class="text-xs px-3 py-1 rounded-full border border-slate-600 text-slate-300 hover:border-indigo-400 hover:text-indigo-300 transition-all"
          >
            English
          </button>
        </div>
      </nav>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-slate-700 mt-16 py-6 text-center text-sm text-slate-500">
      Explore Physics – Interactive physics for students
    </footer>
    <script is:inline>
      (function() {
        const lang = localStorage.getItem('lang') || 'de';
        document.documentElement.lang = lang;
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = lang === 'de' ? 'English' : 'Deutsch';
        btn?.addEventListener('click', () => {
          const current = localStorage.getItem('lang') || 'de';
          const next = current === 'de' ? 'en' : 'de';
          localStorage.setItem('lang', next);
          window.location.reload();
        });
      })();
    </script>
  </body>
</html>
